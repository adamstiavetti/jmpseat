NEXT_PUBLIC_WAITLIST_FORM_URL=

# Required for any deployment that enables jmpseat auth or protects /app
# through Supabase Auth. Local build, test, and docs work can leave these
# unset, but login, signup, reset-password, callback, and protected /app auth
# behavior will not function without them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public canonical app URL used to build app-generated confirmation links.
# Set this per environment, for example to the Vercel preview or production URL.
NEXT_PUBLIC_APP_URL=

# Server-only. Required for app-generated transactional email, including
# airline employee email confirmation. Do not expose either value through
# NEXT_PUBLIC and do not commit real values.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# App launch/access mode. Allowed values:
# - private_testing
# - first_base_launch
# - broader_launch
# - internal_test
# Missing or invalid values safely default to private_testing.
JMPSEAT_LAUNCH_MODE=private_testing

# Server-only. Required only for controlled reviewer proof viewing so the app
# can mint very short-lived signed URLs after reviewer authorization succeeds.
# Do not expose this through NEXT_PUBLIC and do not commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Required only for the protected proof retention cleanup trigger.
# Use this as a shared operator or scheduler secret header value.
# Do not expose this through NEXT_PUBLIC and do not commit a real value.
OPS_CLEANUP_SECRET=

# Server-only. Required only for the one-time initial operator bootstrap route.
# Send this value in x-jmpseat-operator-bootstrap-secret, never in a query
# string. Remove or rotate it after the first active operator grant exists.
# Do not expose this through NEXT_PUBLIC and do not commit a real value.
OPERATOR_BOOTSTRAP_SECRET=

# Server-only. Vercel Cron sends this value as Authorization: Bearer
# <CRON_SECRET>. For the proof-retention cleanup cron route, set this to the
# same value as OPS_CLEANUP_SECRET unless a later route-specific cron secret is
# implemented. Do not expose this through NEXT_PUBLIC and do not commit a real
# value.
CRON_SECRET=
